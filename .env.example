# ========================
# MongoDB
# ========================
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/pakvel?retryWrites=true&w=majority
DB_NAME=pakvel

# ========================
# JWT (Backend tokens)
# ========================
JWT_SECRET=your_jwt_secret_key_here
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
JWT_REFRESH_SECRET=your_refresh_secret_key_here
JWT_REFRESH_EXPIRE_DAYS=30

# ========================
# CORS
# ========================
# Set to "false" in production and list specific origins
CORS_ALLOW_ALL=true
CORS_ORIGINS=http://localhost:3000,http://localhost:8081,http://localhost:19006,http://10.0.2.2:8081

# ========================
# External APIs
# ========================
GROQ_API_KEY=your_groq_api_key
OPENWEATHER_API_KEY=your_openweather_api_key
COMETCHAT_APP_ID=your_cometchat_app_id
COMETCHAT_REGION=in
COMETCHAT_API_KEY=your_cometchat_api_key
COMETCHAT_AUTH_KEY=your_cometchat_auth_key
