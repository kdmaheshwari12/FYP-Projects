# ============================================================
# .env.example — Safe to commit. Shows required variables.
# Copy this to .env and fill in real values locally.
# On Railway, set these in the dashboard (Variables tab).
# ============================================================

MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/?appName=Cluster0
DB_NAME=pakvel

JWT_SECRET=your-strong-secret-key-here
JWT_ALGORITHM=HS256

GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

GROQ_API_KEY=your-groq-api-key
OPENWEATHER_KEY=your-openweather-api-key
INDEX_PATH=vector_index.faiss
DATASET_PATH=Secret Spots Travel Dataset.csv

COMETCHAT_APP_ID=your-cometchat-app-id
COMETCHAT_REGION=in
COMETCHAT_API_KEY=your-cometchat-api-key
COMETCHAT_AUTH_KEY=your-cometchat-auth-key
